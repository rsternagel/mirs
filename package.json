{
  "name": "mirs",
  "version": "0.0.1",
  "description": "",
  "license": "MIT",
  "author": "Richard Sternagel",
  "scripts": {
    "build": "astro build",
    "clean": "rm -rf .astro && rm -rf node_modules && rm -rf pnpm-lock.yaml && rm -rf dist/*",
    "check": "astro check",
    "dev": "astro dev",
    "lint-css": "stylelint src/**/*astro src/**/*css",
    "preview": "astro preview"
  },
  "dependencies": {
    "astro": "^7.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "sharp": "^0.34.5",
    "stylelint": "^17.13.0",
    "stylelint-config-html": "^1.1.0",
    "stylelint-config-standard": "^40.0.0",
    "typescript": "^6.0.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pnpm run lint-staged"
    }
  },
  "lint-staged": {
    "*.astro": [
      "pnpm check && pnpm lint-css"
    ],
    "*.css": [
      "pnpm check && pnpm lint-css"
    ]
  }
}
